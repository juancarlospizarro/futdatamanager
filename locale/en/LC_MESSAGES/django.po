#: .\football_stats_app\templates\includes\footer.html:55
msgid "¿Cómo me registro?"
msgstr "How do I register?"

#: .\football_stats_app\templates\includes\footer.html:60
msgid "Pulsa en “Registrarse”, rellena el formulario y confirma tu correo."
msgstr "Click on 'Register', fill out the form and confirm your email."

#: .\football_stats_app\templates\includes\footer.html:69
msgid "¿Puedo cambiar mi contraseña?"
msgstr "Can I change my password?"

#: .\football_stats_app\templates\includes\footer.html:74
msgid "Sí, desde “¿Olvidaste tu contraseña?” recibirás un enlace por email."
